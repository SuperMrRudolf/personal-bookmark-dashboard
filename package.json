{
  "name": "personal-bookmark-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "store:assets": "node scripts/generate-store-assets.mjs",
    "store:assets:force": "node scripts/generate-store-assets.mjs --force",
    "store:package": "npm run build && node scripts/package-extension.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/outfit": "^5.2.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "simple-icons": "^16.17.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.1.0",
    "@types/chrome": "^0.1.24",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  }
}
